# Configuration for creativity-steer. `./install.sh` copies this to `.env`.
# `./start.sh` reads this, makes sure the models are present, and launches
# the app. Default runs locally via Ollama (fast, fits a 12 GB GPU).

CS_BACKEND=ollama

# Replies
CS_GEN_BACKEND=ollama
CS_GEN_MODEL=granite4.1:3b

# Judging — same fast model by default. For stronger judging use gemma4:12b
# (slower, more memory).
CS_JUDGE_BACKEND=ollama
CS_JUDGE_MODEL=granite4.1:3b

# Novelty check
CS_EMBED_BACKEND=ollama
CS_EMBED_MODEL=embeddinggemma
CS_ENTAILMENT=deberta
CS_DEBERTA_MODEL=tasksource/deberta-base-long-nli
OLLAMA_HOST=http://localhost:11434

# Web app
CS_HOST=127.0.0.1
CS_PORT=8000

# ---------------------------------------------------------------------------
# ADVANCED — run a model you've fine-tuned with Unsloth (served over its
# OpenAI-compatible API). Point a role at it; start.sh launches the server.
# See docs/DEVELOPERS.md for details and caveats (gemma-4 GGUFs force
# chain-of-thought that can't be disabled, so they don't suit this pipeline).
#   CS_GEN_BACKEND=api
#   CS_GEN_MODEL=<your-model-id>
#   CS_GEN_API_BASE_URL=http://localhost:8001/v1
#   CS_CONTEXT=8192
# ---------------------------------------------------------------------------
