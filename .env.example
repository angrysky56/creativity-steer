# Configuration for creativity-steer. `./install.sh` copies this to `.env`.
# `./start.sh` downloads the model (first run), launches it, and starts the app.
#
# DEFAULT: Gemma-4 E4B (Unsloth GGUF) served via llama.cpp's llama-server with
# thinking OFF. One model handles replies and judging — fits a 12 GB GPU.

CS_MEMORY_BACKEND=chroma
CS_GROUNDING=on
CS_MCP_CONFIG=./mcp.json

CS_BACKEND=api

# Replies
CS_GEN_BACKEND=api
CS_GEN_MODEL=gemma-4-E4B-it-qat-GGUF
CS_GEN_HF=unsloth/gemma-4-E4B-it-qat-GGUF:UD-Q4_K_XL
CS_GEN_API_BASE_URL=http://localhost:8001/v1

# Judging — same server as replies (one model, fits 12 GB)
CS_JUDGE_BACKEND=api
CS_JUDGE_MODEL=gemma-4-E4B-it-qat-GGUF
CS_JUDGE_HF=unsloth/gemma-4-E4B-it-qat-GGUF:UD-Q4_K_XL
CS_JUDGE_API_BASE_URL=http://localhost:8001/v1

# Novelty check (local)
CS_EMBED_BACKEND=ollama
CS_EMBED_MODEL=embeddinggemma
CS_ENTAILMENT=deberta
CS_DEBERTA_MODEL=tasksource/deberta-base-long-nli
OLLAMA_HOST=http://localhost:11434

# Web app + model context window (smaller = less VRAM, faster)
CS_HOST=127.0.0.1
CS_PORT=8000
CS_CONTEXT=8192

# ---------------------------------------------------------------------------
# Bigger GPU? Judge with the 12B on its own server (give it a different port):
#   CS_JUDGE_MODEL=gemma-4-12B-it-qat-GGUF
#   CS_JUDGE_HF=unsloth/gemma-4-12B-it-qat-GGUF:UD-Q4_K_XL
#   CS_JUDGE_API_BASE_URL=http://localhost:8002/v1
#
# Prefer all-local Ollama instead of llama-server:
#   CS_BACKEND=ollama
#   CS_GEN_MODEL=granite4.1:3b
#   CS_JUDGE_MODEL=granite4.1:3b
#
# Use a model you fine-tuned: point CS_GEN_HF at your repo:quant (or a local
# path) and CS_GEN_MODEL at any alias. See docs/DEVELOPERS.md.
# ---------------------------------------------------------------------------
